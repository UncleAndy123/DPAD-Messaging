<?xml version="1.0" encoding="utf-8"?>
<!--
    "Sending…" indicator row — shown while a message is in the outbox.
    Focusable but no actions available until send completes.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:focusable="false"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingTop="@dimen/bubble_margin_v"
    android:paddingBottom="@dimen/bubble_margin_v">

    <LinearLayout
        android:id="@+id/bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/bubble_margin_h"
        android:background="@drawable/bubble_sent"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        android:paddingStart="@dimen/bubble_padding_h"
        android:paddingEnd="@dimen/bubble_padding_h"
        android:paddingTop="@dimen/bubble_padding_v"
        android:paddingBottom="@dimen/bubble_padding_v"
        android:alpha="0.6">

        <TextView
            android:id="@+id/tv_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:textColor="@color/bubbleSentText"
            android:textSize="@dimen/text_size_normal" />

        <ImageView
            android:id="@+id/iv_attachment"
            android:layout_width="@dimen/attachment_image_width"
            android:layout_height="@dimen/attachment_image_height"
            android:layout_marginTop="@dimen/padding_tiny"
            android:focusable="false"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_tiny"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_scheduled"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/ic_scheduled"
                android:tint="@color/messageMetaOnSent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:text="@string/sending"
                android:textColor="@color/messageMetaOnSent"
                android:textSize="@dimen/text_size_small"
                android:textStyle="italic" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
